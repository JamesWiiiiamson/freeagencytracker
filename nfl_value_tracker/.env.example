# Copy this file to .env and fill in your real values.
# Never commit .env to source control.

# Sportradar API Keys — get yours at https://developer.sportradar.com
SPORTRADAR_NFL_KEY=your_nfl_key_here
SPORTRADAR_TRANSACTIONS_KEY=your_transactions_key_here

# PostgreSQL connection string
DB_URL=postgresql://USER:PASSWORD@HOST:5432/nfl_value_tracker
